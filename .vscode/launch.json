{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch GRID Launcher",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/grid-launcher.py",
            "python": "${workspaceFolder}/.venv/bin/python3",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Desktop Mode",
            "type": "debugpy",
            "request": "launch",
            "program": "grid-launcher.py",
            "python": "${workspaceFolder}/.venv/bin/python3",
            "console": "integratedTerminal"
        },
        {
            "name": "TV Mode",
            "type": "debugpy",
            "request": "launch",
            "program": "grid-launcher.py",
            "args": ["-tv"],
            "python": "${workspaceFolder}/.venv/bin/python3",
            "console": "integratedTerminal"
        }
    ]
}